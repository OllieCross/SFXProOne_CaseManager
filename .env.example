# == Database ==
# Connection string used by Prisma (points to the postgres service in docker-compose)
DATABASE_URL="postgresql://POSTGRES_USER:POSTGRES_PASSWORD@postgres:5432/POSTGRES_DB"

POSTGRES_USER=casemanager
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=casemanager

# == Redis ==
# Used for rate-limiting; password must match REDIS_PASSWORD below
REDIS_URL="redis://:changeme_redis_password@redis:6379"
REDIS_PASSWORD=changeme_redis_password

# == MinIO (S3-compatible object storage) ==
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme_minio_password
MINIO_BUCKET=casemanager
# Public URL that the browser uses to PUT files directly to MinIO.
# Must be reachable from the client over HTTPS.
# e.g. https://minio.sfxproone.olliecross.com  (if MinIO is exposed via Traefik)
# or   https://sfxproone.olliecross.com/minio   (if proxied through the app domain)
MINIO_PUBLIC_URL=https://minio.sfxproone.olliecross.com

# == NextAuth v5 ==
# Must match the public-facing URL of the app
NEXTAUTH_URL=https://sfxproone.olliecross.com
# Generate with: openssl rand -base64 32
AUTH_SECRET=generate_a_secret_here
# Required when running behind a reverse proxy (Traefik, nginx, etc.)
AUTH_TRUST_HOST=true

# == Authentik OIDC ==
# Obtained from the Authentik admin panel when creating an OAuth2 provider
AUTHENTIK_CLIENT_ID=
AUTHENTIK_CLIENT_SECRET=
# e.g. https://auth.olliecross.com/application/o/casemanager/
AUTHENTIK_ISSUER=
