generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  VIEWER
  EDITOR
  ADMIN
}

enum DocType {
  Manual
  Certificate
  Other
  Bill
  Order
  Invoice
  ServiceReport
}

enum DeviceStatus {
  Working
  Faulty
  InRepair
  Retired
  Lost
  RentedToFriend
}

enum EventStatus {
  Planned
  Confirmed
  Completed
  Cancelled
  NeedsDetails
}

enum InvoiceStatus {
  Paid
  NotPaid
  DepositPaid
  DepositNotYetPaid
  NotPaidInFull
}

enum PyroCategory {
  T1
  T2
  F1
  F2
  F3
  F4
  P1
  P2
  Other
}

enum ChemicalCompound {
  H2O
  O2
  CO2
  C4H10C3H8
  N2
  H2
  LN2
  Other
}

model User {
  id                   String                @id @default(cuid())
  name                 String
  email                String                @unique
  password             String?
  createdAt            DateTime              @default(now())
  role                 Role                  @default(VIEWER)
  casesCreated         Case[]                @relation("CreatedBy")
  casesUpdated         Case[]                @relation("UpdatedBy")
  auditLogs            AuditLog[]
  logbookEntries       LogbookEntry[]
  eventStagehands      EventStagehand[]
  issueEntries         IssueEntry[]
  tanksCreated         Tank[]                @relation("TankCreatedBy")
  tanksUpdated         Tank[]                @relation("TankUpdatedBy")
  tankLogbookEntries   TankLogbookEntry[]
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  targetId  String?
  meta      Json?
  createdAt DateTime @default(now())

  @@index([createdAt(sort: Desc)])
}

model Case {
  id                String       @id @default(cuid())
  name              String
  description       String?
  // qrdata holds the raw QR code payload - could be a UUID string, legacy Google Keep URL,
  // or any other arbitrary string read from a physical sticker.
  qrdata            String       @unique
  warehouseLocation String?
  notes             String?
  items             Item[]
  devices           Device[]
  images            Image[]
  documents         Document[]
  createdById       String
  createdBy         User         @relation("CreatedBy", fields: [createdById], references: [id])
  updatedById       String?
  updatedBy         User?        @relation("UpdatedBy", fields: [updatedById], references: [id])
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  groupCases        GroupCase[]
  eventCases        EventCase[]
  issueEntries      IssueEntry[]
  deletedAt         DateTime?
}

model Item {
  id         String      @id @default(cuid())
  caseId     String?
  case       Case?       @relation(fields: [caseId], references: [id], onDelete: Cascade)
  name       String
  quantity   Int         @default(1)
  comment    String?
  sortOrder  Int         @default(0)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  groupItems   GroupItem[]
  eventItems   EventItem[]
  issueEntries IssueEntry[]
  deletedAt    DateTime?
}

model Image {
  id        String    @id @default(cuid())
  caseId    String
  case      Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  fileKey   String    @unique
  fileName  String
  fileSize  Int
  mimeType  String
  createdAt DateTime  @default(now())
  deletedAt DateTime?
}

model Document {
  id        String    @id @default(cuid())
  caseId    String
  case      Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  title     String
  type      DocType
  fileKey   String    @unique
  fileName  String
  fileSize  Int
  mimeType  String
  createdAt DateTime  @default(now())
  deletedAt DateTime?
}

model Device {
  id             String          @id @default(cuid())
  name           String
  qrCode         String          @unique
  serialNumber   String?
  purchaseDate   DateTime?
  status         DeviceStatus    @default(Working)
  caseId         String?
  case           Case?           @relation(fields: [caseId], references: [id])
  notes          String?
  images         DeviceImage[]
  documents      DeviceDocument[]
  logbook        LogbookEntry[]
  groupDevices   GroupDevice[]
  eventDevices   EventDevice[]
  issueEntries   IssueEntry[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deletedAt      DateTime?
}

model LogbookEntry {
  id        String   @id @default(cuid())
  deviceId  String
  device    Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  date      DateTime
  comment   String
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model DeviceImage {
  id        String    @id @default(cuid())
  deviceId  String
  device    Device    @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  fileKey   String    @unique
  fileName  String
  fileSize  Int
  mimeType  String
  createdAt DateTime  @default(now())
  deletedAt DateTime?
}

model DeviceDocument {
  id        String    @id @default(cuid())
  deviceId  String
  device    Device    @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  title     String
  type      DocType
  fileKey   String    @unique
  fileName  String
  fileSize  Int
  mimeType  String
  createdAt DateTime  @default(now())
  deletedAt DateTime?
}

model Consumable {
  id                String             @id @default(cuid())
  name              String
  unit              String
  stockQuantity     Float              @default(0)
  warningThreshold  Float?
  criticalThreshold Float?
  notes             String?
  groupConsumables  GroupConsumable[]
  eventConsumables  EventConsumable[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  deletedAt         DateTime?
}

model Group {
  id               String            @id @default(cuid())
  name             String
  cases            GroupCase[]
  devices          GroupDevice[]
  items            GroupItem[]
  consumables      GroupConsumable[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model GroupCase {
  groupId String
  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  caseId  String
  case    Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@id([groupId, caseId])
}

model GroupDevice {
  groupId  String
  group    Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  deviceId String
  device   Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@id([groupId, deviceId])
}

model GroupItem {
  groupId String
  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  itemId  String
  item    Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@id([groupId, itemId])
}

model GroupConsumable {
  groupId        String
  group          Group      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  consumableId   String
  consumable     Consumable @relation(fields: [consumableId], references: [id], onDelete: Cascade)
  quantityNeeded Float      @default(1)

  @@id([groupId, consumableId])
}

model Event {
  id            String           @id @default(cuid())
  name          String
  venueName     String
  location      String?
  startDate     DateTime
  clientName    String?
  clientPhone   String?
  clientEmail   String?
  comments      String?
  status        EventStatus      @default(Planned)
  invoiceStatus InvoiceStatus    @default(NotPaid)
  stagehands    EventStagehand[]
  cases         EventCase[]
  devices       EventDevice[]
  items         EventItem[]
  consumables   EventConsumable[]
  tanks         EventTank[]
  pyros         EventPyro[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
}

model EventStagehand {
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId  String
  user    User   @relation(fields: [userId], references: [id])

  @@id([eventId, userId])
}

model EventCase {
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  caseId  String
  case    Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@id([eventId, caseId])
}

model EventDevice {
  eventId  String
  event    Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  deviceId String
  device   Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@id([eventId, deviceId])
}

model EventItem {
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  itemId  String
  item    Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@id([eventId, itemId])
}

model EventConsumable {
  eventId        String
  event          Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  consumableId   String
  consumable     Consumable @relation(fields: [consumableId], references: [id], onDelete: Cascade)
  quantityNeeded Float
  quantityUsed   Float?

  @@id([eventId, consumableId])
}

model Tank {
  id               String             @id @default(cuid())
  name             String
  qrCode           String?            @unique
  chemicalCompound ChemicalCompound   @default(Other)
  unit             String
  fullCapacity     Float
  currentCapacity  Float
  notes            String?
  images           TankImage[]
  documents        TankDocument[]
  logbook          TankLogbookEntry[]
  eventTanks       EventTank[]
  createdById      String
  createdBy        User               @relation("TankCreatedBy", fields: [createdById], references: [id])
  updatedById      String?
  updatedBy        User?              @relation("TankUpdatedBy", fields: [updatedById], references: [id])
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  deletedAt        DateTime?
}

model TankImage {
  id        String    @id @default(cuid())
  tankId    String
  tank      Tank      @relation(fields: [tankId], references: [id], onDelete: Cascade)
  fileKey   String    @unique
  fileName  String
  fileSize  Int
  mimeType  String
  createdAt DateTime  @default(now())
  deletedAt DateTime?
}

model TankDocument {
  id        String    @id @default(cuid())
  tankId    String
  tank      Tank      @relation(fields: [tankId], references: [id], onDelete: Cascade)
  title     String
  type      DocType
  fileKey   String    @unique
  fileName  String
  fileSize  Int
  mimeType  String
  createdAt DateTime  @default(now())
  deletedAt DateTime?
}

model TankLogbookEntry {
  id        String   @id @default(cuid())
  tankId    String
  tank      Tank     @relation(fields: [tankId], references: [id], onDelete: Cascade)
  date      DateTime
  comment   String
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model EventTank {
  eventId         String
  event           Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  tankId          String
  tank            Tank   @relation(fields: [tankId], references: [id], onDelete: Cascade)
  quantityNeeded  Float?

  @@id([eventId, tankId])
}

model Pyro {
  id                String       @id @default(cuid())
  name              String
  brand             String?
  category          PyroCategory @default(Other)
  stockQuantity     Int          @default(0)
  warningThreshold  Int?
  criticalThreshold Int?
  notes             String?
  images            PyroImage[]
  documents         PyroDocument[]
  eventPyros        EventPyro[]
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  deletedAt         DateTime?
}

model PyroImage {
  id        String    @id @default(cuid())
  pyroId    String
  pyro      Pyro      @relation(fields: [pyroId], references: [id], onDelete: Cascade)
  fileKey   String    @unique
  fileName  String
  fileSize  Int
  mimeType  String
  createdAt DateTime  @default(now())
  deletedAt DateTime?
}

model PyroDocument {
  id        String    @id @default(cuid())
  pyroId    String
  pyro      Pyro      @relation(fields: [pyroId], references: [id], onDelete: Cascade)
  title     String
  type      DocType
  fileKey   String    @unique
  fileName  String
  fileSize  Int
  mimeType  String
  createdAt DateTime  @default(now())
  deletedAt DateTime?
}

model EventPyro {
  eventId        String
  event          Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  pyroId         String
  pyro           Pyro   @relation(fields: [pyroId], references: [id], onDelete: Cascade)
  quantityNeeded Int

  @@id([eventId, pyroId])
}

model IssueEntry {
  id          String   @id @default(cuid())
  description String
  deviceId    String?
  device      Device?  @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  caseId      String?
  case        Case?    @relation(fields: [caseId], references: [id], onDelete: SetNull)
  itemId      String?
  item        Item?    @relation(fields: [itemId], references: [id], onDelete: SetNull)
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
}
